{
  "name": "doc_generate",
  "version": "1.0.0",
  "description": "自动生成代码文档，包括函数注释、API文档、使用说明等",
  "author": "ReAct Agent Framework",
  "parameters": {
    "type": "object",
    "properties": {
      "source_path": {
        "type": "string",
        "description": "源代码文件或目录的路径"
      },
      "doc_type": {
        "type": "string",
        "enum": ["api", "readme", "inline", "guide"],
        "description": "文档类型：api(API文档)、readme(项目说明)、inline(内联注释)、guide(使用指南)"
      },
      "output_path": {
        "type": "string",
        "description": "文档输出路径"
      },
      "style": {
        "type": "string",
        "enum": ["jsdoc", "markdown", "google", "standard"],
        "default": "markdown",
        "description": "文档风格"
      }
    },
    "required": ["source_path", "doc_type"]
  },
  "workflow": {
    "steps": [
      {
        "id": "read_source",
        "type": "tool",
        "tool": "file_reader",
        "input": {
          "path": "{{parameters.source_path}}"
        }
      },
      {
        "id": "generate_doc",
        "type": "llm",
        "prompt": "请为以下代码生成{{parameters.doc_type}}类型的文档，使用{{parameters.style}}风格：\n\n```\n{{steps.read_source.output.content}}\n```\n\n要求：\n1. 文档应清晰、完整、专业\n2. 包含所有公共API的说明\n3. 提供使用示例\n4. 遵循{{parameters.style}}文档规范",
        "output_key": "generated_documentation"
      },
      {
        "id": "save_doc",
        "type": "tool",
        "condition": "{{parameters.output_path}}",
        "tool": "file_writer",
        "input": {
          "path": "{{parameters.output_path}}",
          "content": "{{steps.generate_doc.output}}"
        }
      }
    ]
  },
  "knowledge": {
    "examples": [
      {
        "input": {
          "source_path": "/src/utils.js",
          "doc_type": "api",
          "style": "jsdoc"
        },
        "description": "为工具函数生成JSDoc风格的API文档"
      }
    ],
    "best_practices": [
      "API文档应包含参数类型、返回值和异常说明",
      "README文档应包含安装、配置、使用说明",
      "内联注释应解释'为什么'而非'是什么'"
    ]
  }
}
